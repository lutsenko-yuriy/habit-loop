# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Generated l10n Dart files — source of truth is lib/l10n/*.arb; run `flutter gen-l10n` to regenerate
lib/l10n/generated/

# Firebase credentials — must NOT be committed; generate via flutterfire configure
google-services.json
GoogleService-Info.plist
lib/firebase_options.dart

# Android signing — must NOT be committed
upload-keystore.jks
android/key.properties
