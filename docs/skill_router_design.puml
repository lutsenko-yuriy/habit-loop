@startuml skill_router_design
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam defaultFontSize 12

' ── Standalone repo ────────────────────────────────────────────────────────
package "skill-router  (standalone repo)" as repo {

  package "skill_router/" as pkg {

    component [__main__.py\nCLI entry point] as main
    component [config.py\nloads skill_router.toml\n+ env var overrides] as config  #LightYellow
    component [frontmatter.py\nparse SKILL.md\nlook up model tier] as frontmatter
    component [constants.py\ndefaults only\n(no hardcoded IDs)] as constants
    component [streaming.py\nLM Studio HTTP\nstreaming output] as streaming
    component [tool_loop.py\nagentic turn loop] as tool_loop
    component [linear_client.py\nGraphQL context fetch\n+ tool definitions] as linear
    component [github_client.py\nPR / diff context] as github
    component [files_client.py\nfile read context] as files
  }

  file "pyproject.toml\n(declares 'skill-router' CLI command)" as pyproject
}

note right of config
  New file.
  Reads skill_router.toml
  from project root.
  Secrets stay in env vars.
end note

note right of constants
  Changed: removes hardcoded
  LINEAR_PROJECT_ID and
  MODEL_TIERS_PATH.
  Becomes pure defaults.
end note

' ── Project config ─────────────────────────────────────────────────────────
file "skill_router.toml\n(sits at consuming project root)" as toml

note bottom of toml
  [skill_router]
  model_tiers_path = "docs/MODEL_TIERS.md"

  [linear]
  project_id = "c3afdc26-..."

  [lmstudio]
  base_url = "http://localhost:1234/v1"
end note

' ── Consuming project: habit-loop ──────────────────────────────────────────
package "habit-loop  (consuming project)" as hl {
  file "skill_router.toml" as hl_toml
  component [scripts/skill_router.py\nthin shim (stays)] as hl_shim
  folder "skills/**/*.md" as skills
  file "docs/MODEL_TIERS.md" as tiers
}

' ── External ───────────────────────────────────────────────────────────────
cloud "LM Studio\n(localhost:1234)" as lmstudio
cloud "Linear API\n(api.linear.app)" as linearapi

' ── Internal wiring ────────────────────────────────────────────────────────
main --> config      : 1. load config
main --> frontmatter : 2. parse skill
main --> streaming   : 3a. no-tools path
main --> tool_loop   : 3b. with-tools path
config --> constants : fills defaults
frontmatter --> tiers : reads (path from config)
tool_loop --> linear  : tool group "linear"
tool_loop --> github  : tool group "github"
tool_loop --> files   : tool group "files"
streaming --> lmstudio
tool_loop --> lmstudio

' ── Cross-repo wiring ──────────────────────────────────────────────────────
hl_shim ..> pkg      : pip install\ngit+https://github.com/.../skill-router
hl_toml ..> config   : loaded at startup
skills ..> main      : <skill_path> argument
linear --> linearapi

@enduml
